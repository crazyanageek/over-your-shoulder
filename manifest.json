{
  "manifest_version": 3,
  "name": "Over Your Shoulder",
  "version": "0.1.0",
  "description": "See where your AI queries actually go. All analysis stays on your device.",
  "permissions": ["storage", "webRequest", "alarms"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://openai.com/*",
    "https://api.anthropic.com/*",
    "https://claude.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://api.cognitive.microsoft.com/*",
    "https://api.mistral.ai/*",
    "https://chat.mistral.ai/*",
    "https://api.cohere.com/*",
    "https://dashboard.cohere.com/*",
    "https://api.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://api.x.ai/*",
    "https://grok.com/*",
    "https://api-inference.huggingface.co/*",
    "https://huggingface.co/*",
    "https://api.together.xyz/*",
    "https://api.together.ai/*",
    "https://api.groq.com/*",
    "https://api.deepseek.com/*",
    "https://chat.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["report/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
